function switchCinemaTab(tabName) {
  document.querySelectorAll(".cinema-pane").forEach(pane => pane.classList.add("hidden"));
  document.getElementById("pane-" + tabName).classList.remove("hidden");
  
  document.querySelectorAll(".cinema-pane-tab").forEach(btn => {
    btn.classList.remove("bg-white", "shadow-sm", "border-slate-200");
    btn.style.color = "var(--text-dim)";
  });
  
  const activeBtn = document.getElementById("tab-" + tabName);
  if (activeBtn) {
    activeBtn.classList.add("bg-white", "shadow-sm", "border-slate-200");
    activeBtn.style.color = "var(--cyan)";
  }
}

async function importCinemaFolder(event) {
    const files = event.target.files;
    const statusList = document.getElementById("assets-status-list");
    const statusContainer = document.getElementById("loaded-assets-status");
    
    logCinemaConsole("Système", `Analyse de ${files.length} fichiers dans votre dossier...`);
    
    let agentsImportes = 0;
    let persosImportes = false;
    let loreImporte = false;

    for (let file of files) {
        if (file.name.endsWith('.json')) {
            const reader = new FileReader();
            await new Promise((resolve) => {
                reader.onload = async (e) => {
                    try {
                        const json = JSON.parse(e.target.result);
                        if (json.type === "agent") {
                            const agentData = {
                                id: json.id || uuid(),
                                name: json.name,
                                desc: json.desc || "Agent importé",
                                instructions: json.instructions,
                                primer: json.primer || "",
                                tags: json.tags || ["cinema"],
                                modelPref: json.modelPref || "mistral-large-2512",
                                temperature: json.temperature || 0.7,
                                maxTokens: json.maxTokens || 4096,
                                created: now()
                            };
                            await db.put('agents', agentData);
                            cinemaProjectAssets.agents[json.id] = agentData;
                            agentsImportes++;
                        } else if (json.type === "characters") {
                            cinemaProjectAssets.characters = json.list;
                            persosImportes = true;
                        } else if (json.type === "lore") {
                            cinemaProjectAssets.lore = json;
                            loreImporte = true;
                        }
                    } catch(err) {
                        console.error(`Erreur ${file.name}:`, err);
                    }
                    resolve();
                };
                reader.readAsText(file);
            });
        }
    }

    statusContainer.classList.remove("hidden");
    statusList.innerHTML = "";
    
    if (agentsImportes > 0) {
        statusList.innerHTML += `<div class="text-xs font-semibold" style="color:var(--success);">✅ ${agentsImportes} Agent(s) Cinema chargés</div>`;
        await loadAgents();
    }
    if (persosImportes) {
        statusList.innerHTML += `<div class="text-xs font-semibold" style="color:var(--success);">👤 Personnages chargés (${cinemaProjectAssets.characters.length})</div>`;
    }
    if (loreImporte) {
        statusList.innerHTML += `<div class="text-xs font-semibold" style="color:var(--success);">📖 Trame et lore synchronisés</div>`;
    }
    
    logCinemaConsole("Système", "Synchronisation du dossier local complétée !");
    toast("Projet cinéma importé avec succès !", "success");
}

async function runCinemaScenarist() {
  const title = document.getElementById("cinema-title").value.trim() || "Sans titre";
  const pitch = document.getElementById("cinema-pitch").value.trim();
  
  if (!pitch && !cinemaProjectAssets.lore) {
    toast("Rédigez d'abord un synopsis ou importez vos JSON d'histoire.", "error");
    return;
  }
  
  if (!state.apiKey) {
    toast("Configurez votre clé API d'abord.", "error");
    document.getElementById('api-modal').classList.add("active");
    return;
  }

  setCinemaStepStatus("scenarist", "RÉDACTION...", "text-amber-500 animate-pulse");
  logCinemaConsole("Scénariste", "Début de la rédaction créative...");
  switchCinemaTab('scénario');

  try {
    const agent = await db.get('agents', 'agent-scenariste') || agentsConfig.screenplay;
    const systemPrompt = agent ? agent.instructions : agentsConfig.screenplay.system_prompt;
    
    let userPrompt = `Titre du projet : ${title}\nPitch: ${pitch}\n\n`;
    if (cinemaProjectAssets.characters) {
        userPrompt += `Personnages à inclure absolument:\n${JSON.stringify(cinemaProjectAssets.characters, null, 2)}\n\n`;
    }
    if (cinemaProjectAssets.lore) {
        userPrompt += `Univers et synopsis de référence:\n${JSON.stringify(cinemaProjectAssets.lore, null, 2)}\n\n`;
    }
    userPrompt += `Rédige un scénario de cinéma captivant.`;
    
    const reply = await callMistralDirect(systemPrompt, userPrompt, agent?.modelPref || "codestral-2508", agent?.temperature || 0.7);
    document.getElementById("cinema-scenario-text").value = reply;
    setCinemaStepStatus("scenarist", "PRÊT", "text-emerald-500");
    logCinemaConsole("Scénariste", "Scénario rédigé avec succès !");
  } catch(e) {
    setCinemaStepStatus("scenarist", "ERREUR", "text-rose-500");
    logCinemaConsole("Erreur", e.message);
  }
}

async function runCinemaDirector() {
  const scenario = document.getElementById("cinema-scenario-text").value.trim();
